NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Leave SMTP unset — form submissions are stored in the admin panel, not emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_RECIPIENT=support@pomeloagency.com

# --- Firebase (talent roster / admin panel) ---
# Put the downloaded service account key at server/serviceAccountKey.json.
# NOTE: Cloud Functions reserves env keys named PORT or starting with FIREBASE_ /
# GOOGLE_ / EXT_ — don't use those names here or deploys will fail.
STORAGE_BUCKET=your-project.firebasestorage.app
# Comma-separated emails allowed to sign in to /admin
ADMIN_EMAILS=admin@pomeloagency.com
