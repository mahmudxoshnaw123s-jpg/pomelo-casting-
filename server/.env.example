PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Leave SMTP unset in development — submissions will be logged instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
CONTACT_RECIPIENT=support@pomeloagency.com

# --- Firebase (talent roster / admin panel) ---
# Easiest: drop the downloaded key at server/serviceAccountKey.json and leave the
# FIREBASE_PROJECT_ID / CLIENT_EMAIL / PRIVATE_KEY vars below blank.
# Otherwise, fill these from the service account JSON (keep the \n escapes in the key):
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# The Storage bucket, e.g. your-project.appspot.com or your-project.firebasestorage.app
FIREBASE_STORAGE_BUCKET=
# Comma-separated emails allowed to sign in to /admin
ADMIN_EMAILS=admin@pomeloagency.com
